# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/market?schema=public"

# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""

# Groq (verification agents) — free tier, OpenAI-compatible API
GROQ_API_KEY=""

# ConvertAPI (used by the demo docx->pdf worker adapter)
CONVERTAPI_SECRET=""

# Crypto payments (USDC on Base). Defaults to Base Sepolia (testnet) unless
# CRYPTO_NETWORK=mainnet. This wallet both receives buyer deposits and signs
# payout/refund transfers — MVP-only, fund it minimally, rotate to a
# managed-custody signer before handling real volume.
CRYPTO_NETWORK="testnet"
PLATFORM_WALLET_PRIVATE_KEY=""

# Auth (Google sign-in)
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Google Ad Manager rewarded ads (see /credits/earn). Public — safe to expose
# client-side, it's just an inventory path, not a secret. Defaults to
# Google's own published test rewarded ad unit if unset, so the flow works
# before you have a real GAM network. Format: /network-code/ad-unit-code.
NEXT_PUBLIC_GAM_REWARDED_AD_UNIT_PATH="/22639388115/rewarded_web_example"

# Google Ad Manager standard display ads (margin ads on /workers, banner on
# /credits/earn — see components/display-ad.tsx). Same deal: public, and
# defaults to Google's published test display ad unit until you have a real
# network/ad unit of your own.
NEXT_PUBLIC_GAM_DISPLAY_AD_UNIT_PATH="/6355419/Travel/Europe/France/Paris"
